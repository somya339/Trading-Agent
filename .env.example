# OpenAI
OPENAI_API_KEY=your_openai_key_here

# Zerodha Kite Connect
ZERODHA_API_KEY=your_kite_api_key
ZERODHA_API_SECRET=your_kite_api_secret
ZERODHA_ACCESS_TOKEN=your_access_token
ZERODHA_REQUEST_TOKEN=

# Kite web session (watchlists — from kite.zerodha.com cookies after login)
ZERODHA_ENCTOKEN=
ZERODHA_PUBLIC_TOKEN=
ZERODHA_USER_ID=
ZERODHA_KF_SESSION=

# Trading Configuration
CAPITAL=100000
MAX_SIGNALS=5
RUN_INTERVAL_MINUTES=15

# Risk profile: conservative | balanced | aggressive
# Sets risk/trade, portfolio heat cap, position/sector concentration, stop width,
# signal gates, and strategy aggressiveness in one switch.
#   aggressive = HIGH risk appetite: 2% risk/trade, 12% heat cap, up to 25%/position,
#                wider 3xATR stops, looser entries, bigger target ladders.
# WARNING: aggressive amplifies BOTH returns and losses. Paper-trade to confirm a
# positive edge (profit factor > 1 after costs) BEFORE committing real capital.
RISK_PROFILE=balanced

# Sizing mode:
#   risk       = layered risk engine with per-position/sector/heat caps (default).
#   conviction = NO position caps. Ranks AND sizes by duration-adjusted return
#                (annualized %) × score, so the best profit-per-time trades get
#                the most capital. Suggested sizes are ADVISORY (you allocate
#                manually). By default deployment is UNCAPPED in this mode, so
#                suggested notionals may sum past your cash.
SIZING_MODE=risk
# Cap total suggested deployment as a multiple of capital (e.g. 1 = within cash,
# 1.5 = up to 1.5x via margin). Unset in conviction mode = uncapped.
# MAX_TOTAL_DEPLOYMENT_PCT=1

# Any individual knob below overrides the profile default (leave unset to use profile):
# RISK_PER_TRADE_PCT=0.02
# MAX_PORTFOLIO_HEAT_PCT=0.12
# MAX_POSITION_PCT=0.25
# MAX_SECTOR_PCT=0.50
# MAX_OPEN_POSITIONS=15
# BUY_SCORE_THRESHOLD=52
# MIN_SENTIMENT=25
# MOMENTUM_MIN_RS=60

# Fundamentals (Screener.in + Zerodha live price adjustment)
SCREENER_REQUEST_DELAY_MS=450
